generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  THERAPIST
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum SessionMedium {
  IN_PERSON
  VIDEO
}

enum StripeAccountStatus {
  NOT_CONNECTED
  ONBOARDING_IN_PROGRESS
  ACTIVE
  RESTRICTED
  DISABLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  ALIPAY
  WECHAT_PAY
}

enum FormStatus {
  DRAFT
  SENT
  SUBMITTED
  ARCHIVED
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
  YES_NO
}

enum TherapyPlanType {
  PERSONAL_CONSULT
  GROUP_CONSULT
  ART_SALON
  WELLNESS_RETREAT
}

enum TherapyPlanStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ArtSalonSubType {
  CALLIGRAPHY
  PAINTING
  DRAMA
  YOGA
  BOARD_GAMES
  CULTURAL_CONVERSATION
}

enum MessageTrigger {
  PLAN_SUBMITTED
  PLAN_APPROVED
  PLAN_REJECTED
  MANUAL
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             Role      @default(CLIENT)
  firstName        String
  lastName         String
  nickname         String?
  age              Int?
  gender           String?
  phone            String?
  avatarUrl        String?
  privacyConsentAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  therapistProfile     TherapistProfile?
  appointmentsAsClient Appointment[]     @relation("ClientAppointments")
  reviews              Review[]
  receivedForms        ClientForm[]      @relation("FormRecipient")
  sentForms            ClientForm[]      @relation("FormSender")
  sentMessages         Message[]         @relation("MessageSender")
  receivedMessages     Message[]         @relation("MessageRecipient")
}

model TherapistProfile {
  id            String              @id @default(cuid())
  userId        String              @unique
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String
  specialties   String[]
  sessionPrice  Decimal             @db.Decimal(10, 2)
  sessionLength Int
  locationCity  String
  isAccepting   Boolean             @default(true)
  rating        Float?

  stripeAccountId     String?
  stripeAccountStatus StripeAccountStatus @default(NOT_CONNECTED)

  appointments  Appointment[]
  availability  Availability[]
  reviews       Review[]
  refundPolicy  RefundPolicy?
  therapyPlans  TherapyPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          String            @id @default(cuid())
  clientId    String
  client      User              @relation("ClientAppointments", fields: [clientId], references: [id])
  therapistId String
  therapist   TherapistProfile  @relation(fields: [therapistId], references: [id])
  startTime   DateTime
  endTime     DateTime
  status      AppointmentStatus @default(PENDING)
  medium      SessionMedium     @default(IN_PERSON)
  clientNotes String?
  createdAt   DateTime          @default(now())

  sessionNote SessionNote?
  payment     Payment?
}

model SessionNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  content       String
  artworkUrl    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Availability {
  id          String           @id @default(cuid())
  therapistId String
  therapist   TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startTime   String
  endTime     String
}

model Review {
  id          String           @id @default(cuid())
  clientId    String
  client      User             @relation(fields: [clientId], references: [id])
  therapistId String
  therapist   TherapistProfile @relation(fields: [therapistId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime         @default(now())
}

model Payment {
  id            String          @id @default(cuid())
  appointmentId String          @unique
  appointment   Appointment     @relation(fields: [appointmentId], references: [id])

  provider      PaymentProvider @default(STRIPE)

  // Stripe fields (null for Alipay/WeChat payments)
  stripePaymentIntentId String?  @unique
  stripeChargeId        String?
  stripeTransferId      String?
  stripeRefundId        String?

  // Alipay / WeChat Pay fields (null for Stripe payments)
  externalOrderId String? // platform-generated order ID sent to the provider
  externalTradeNo String? // provider-assigned transaction number (set after success)

  amount                Int
  currency              String          @default("cny")
  platformFeeAmount     Int
  therapistPayoutAmount Int

  status       PaymentStatus @default(PENDING)
  refundedAt   DateTime?
  refundAmount Int?
  refundReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefundPolicy {
  id          String           @id @default(cuid())
  therapistId String           @unique
  therapist   TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  fullRefundHoursThreshold Int     @default(24)
  allowPartialRefund       Boolean @default(false)
  partialRefundPercent     Int?
  policyDescription        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookEvent {
  id          String    @id
  type        String
  processed   Boolean   @default(false)
  processedAt DateTime?
  rawPayload  Json
  createdAt   DateTime  @default(now())
}

// ─── Client Form System ────────────────────────────────────────────────────────

model ClientForm {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      FormStatus @default(DRAFT)

  senderId    String
  sender      User       @relation("FormSender", fields: [senderId], references: [id])
  recipientId String
  recipient   User       @relation("FormRecipient", fields: [recipientId], references: [id])

  sentAt      DateTime?
  submittedAt DateTime?

  questions   FormQuestion[]
  responses   FormResponse[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormQuestion {
  id       String       @id @default(cuid())
  formId   String
  form     ClientForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  order    Int
  type     QuestionType
  label    String
  required Boolean      @default(false)
  options  String[]
  scaleMin Int?
  scaleMax Int?

  answers  FormAnswer[]
}

model FormResponse {
  id          String       @id @default(cuid())
  formId      String
  form        ClientForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedAt DateTime     @default(now())

  answers     FormAnswer[]
}

model FormAnswer {
  id         String       @id @default(cuid())
  responseId String
  response   FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   FormQuestion @relation(fields: [questionId], references: [id])
  value      String
}

// ─── Therapy Plan System ───────────────────────────────────────────────────────

model TherapyPlan {
  id              String            @id @default(cuid())
  therapistId     String
  therapist       TherapistProfile  @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  type            TherapyPlanType
  status          TherapyPlanStatus @default(DRAFT)

  title           String
  introduction    String
  startTime       DateTime
  endTime         DateTime?
  location        String
  maxParticipants Int?
  contactInfo     String

  // Type-specific fields
  artSalonSubType ArtSalonSubType? // only for ART_SALON
  sessionMedium   SessionMedium?   // only for PERSONAL_CONSULT

  // Poster — one of these two is set, never both
  defaultPosterId Int?             // 1–6 (static file /posters/default-N.jpg)
  posterUrl       String?          // Cloudinary URL for custom upload

  // Review workflow
  rejectionReason String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  publishedAt     DateTime?

  messages        Message[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([type])
  @@index([therapistId])
}

model Message {
  id          String         @id @default(cuid())
  senderId    String?        // null = system-generated
  sender      User?          @relation("MessageSender",    fields: [senderId],    references: [id])
  recipientId String
  recipient   User           @relation("MessageRecipient", fields: [recipientId], references: [id])

  body        String         // plain text + emoji, max 2000 chars
  trigger     MessageTrigger
  isRead      Boolean        @default(false)
  readAt      DateTime?

  planId      String?
  plan        TherapyPlan?   @relation(fields: [planId], references: [id], onDelete: SetNull)

  createdAt   DateTime       @default(now())

  @@index([recipientId, isRead])
  @@index([recipientId])
}
