{
  "name": "art-therapy-server",
  "version": "1.0.0",
  "description": "Art Therapy Appointment API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && esbuild src/server.ts --bundle --platform=node --format=cjs --packages=external --outdir=dist --sourcemap",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "npx --yes tsx prisma/seed.ts",
    "db:backfill:therapy-plan-review-meta": "tsx prisma/scripts/backfill-therapy-plan-review-meta.ts",
    "db:backfill:product-review-meta": "tsx prisma/scripts/backfill-product-review-meta.ts",
    "db:backfill:personal-consult-window": "tsx prisma/scripts/backfill-personal-consult-window.ts",
    "db:backfill:all": "npm run db:backfill:therapy-plan-review-meta && npm run db:backfill:product-review-meta && npm run db:backfill:personal-consult-window",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "alipay-sdk": "^4.14.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "socket.io": "^4.8.1",
    "stripe": "^14.15.0",
    "uuid": "^9.0.0",
    "wechatpay-axios-plugin": "^0.9.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "esbuild": "^0.27.4",
    "prisma": "^5.9.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "npx --yes tsx prisma/seed.ts"
  }
}
