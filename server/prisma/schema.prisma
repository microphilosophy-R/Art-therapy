generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  CANCELLED
  COMPLETED
}

enum SessionMedium {
  IN_PERSON
  VIDEO
}

enum StripeAccountStatus {
  NOT_CONNECTED
  ONBOARDING_IN_PROGRESS
  ACTIVE
  RESTRICTED
  DISABLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  ALIPAY
  WECHAT_PAY
}

enum FormStatus {
  DRAFT
  SENT
  SUBMITTED
  ARCHIVED
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
  YES_NO
}

enum TherapyPlanType {
  PERSONAL_CONSULT
  GROUP_CONSULT
  ART_SALON
  WELLNESS_RETREAT
}

enum TherapyPlanStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  SIGN_UP_CLOSED
  IN_PROGRESS
  FINISHED
  IN_GALLERY
  CANCELLED
  ARCHIVED
}

enum ParticipantStatus {
  PENDING_PAYMENT
  SIGNED_UP
  CANCELLED
}

enum ArtSalonSubType {
  CALLIGRAPHY
  PAINTING
  DRAMA
  YOGA
  BOARD_GAMES
  CULTURAL_CONVERSATION
}

enum MessageTrigger {
  PLAN_SUBMITTED
  PLAN_APPROVED
  PLAN_REJECTED
  MANUAL
  APPOINTMENT_DEADLINE_WARNING
  APPOINTMENT_AUTO_CANCELLED
  PLAN_SIGNUP
  PLAN_SIGNUP_CANCELLED
  PLAN_STARTED
  PLAN_FINISHED
  PLAN_CANCELLED_BY_THERAPIST
  PROFILE_SUBMITTED
  PROFILE_APPROVED
  PROFILE_REJECTED
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

// ─── E-commerce Enums ──────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductCategory {
  PAINTING
  SCULPTURE
  CRAFTS
  DIGITAL_ART
  MERCHANDISE
  OTHER
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

enum CertificateType {
  COUNSELOR
  THERAPIST
  ARTIFICER
}

enum CertificateStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             Role      @default(MEMBER)
  firstName        String
  lastName         String
  nickname         String?
  birthday         DateTime?
  age              Int?
  gender           String?
  country          String?
  religion         String?
  phone            String?
  avatarUrl        String?
  privacyConsentAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  appointmentsAsClient      Appointment[]            @relation("ClientAppointments")
  reviews                   Review[]
  receivedForms             ClientForm[]             @relation("FormRecipient")
  sentForms                 ClientForm[]             @relation("FormSender")
  sentMessages              Message[]                @relation("MessageSender")
  receivedMessages          Message[]                @relation("MessageRecipient")
  therapyPlanParticipations TherapyPlanParticipant[] @relation("UserParticipations")
  templates                 TherapyPlanTemplate[]    @relation("UserTemplates")
  cartItems                 CartItem[]
  orders                    Order[]
  userProfile               UserProfile?
}

model GalleryImage {
  id            String       @id @default(cuid())
  userProfileId String
  userProfile   UserProfile  @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  url           String
  order         Int          @default(0)
  createdAt     DateTime     @default(now())

  @@index([userProfileId])
}

model Appointment {
  id            String            @id @default(cuid())
  clientId      String
  client        User              @relation("ClientAppointments", fields: [clientId], references: [id])
  userProfileId String
  userProfile   UserProfile       @relation(fields: [userProfileId], references: [id])
  startTime     DateTime
  endTime       DateTime
  status        AppointmentStatus @default(PENDING)
  medium        SessionMedium     @default(IN_PERSON)
  clientNotes   String?
  createdAt     DateTime          @default(now())

  sessionNote SessionNote?
  payment     Payment?
}

model SessionNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  content       String
  artworkUrl    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Availability {
  id            String      @id @default(cuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  dayOfWeek     Int
  startTime     String
  endTime       String
}

model Review {
  id            String      @id @default(cuid())
  clientId      String
  client        User        @relation(fields: [clientId], references: [id])
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
}

model Payment {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  provider PaymentProvider @default(STRIPE)

  // Stripe fields (null for Alipay/WeChat payments)
  stripePaymentIntentId String? @unique
  stripeChargeId        String?
  stripeTransferId      String?
  stripeRefundId        String?

  // Alipay / WeChat Pay fields (null for Stripe payments)
  externalOrderId String? // platform-generated order ID sent to the provider
  externalTradeNo String? // provider-assigned transaction number (set after success)

  amount                Int
  currency              String @default("cny")
  platformFeeAmount     Int
  therapistPayoutAmount Int

  status       PaymentStatus @default(PENDING)
  refundedAt   DateTime?
  refundAmount Int?
  refundReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefundPolicy {
  id                       String      @id @default(cuid())
  userProfileId            String      @unique
  userProfile              UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  fullRefundHoursThreshold Int         @default(24)
  allowPartialRefund       Boolean     @default(false)
  partialRefundPercent     Int?
  policyDescription        String
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
}

model WebhookEvent {
  id          String    @id
  type        String
  processed   Boolean   @default(false)
  processedAt DateTime?
  rawPayload  Json
  createdAt   DateTime  @default(now())
}

// ─── Client Form System ────────────────────────────────────────────────────────

model ClientForm {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      FormStatus @default(DRAFT)

  senderId    String
  sender      User   @relation("FormSender", fields: [senderId], references: [id])
  recipientId String
  recipient   User   @relation("FormRecipient", fields: [recipientId], references: [id])

  sentAt      DateTime?
  submittedAt DateTime?

  questions FormQuestion[]
  responses FormResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormQuestion {
  id       String       @id @default(cuid())
  formId   String
  form     ClientForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  order    Int
  type     QuestionType
  label    String
  required Boolean      @default(false)
  options  String[]
  scaleMin Int?
  scaleMax Int?

  answers FormAnswer[]
}

model FormResponse {
  id          String     @id @default(cuid())
  formId      String
  form        ClientForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedAt DateTime   @default(now())

  answers FormAnswer[]
}

model FormAnswer {
  id         String       @id @default(cuid())
  responseId String
  response   FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   FormQuestion @relation(fields: [questionId], references: [id])
  value      String
}

// ─── Therapy Plan System ───────────────────────────────────────────────────────

model TherapyPlan {
  id            String            @id @default(cuid())
  userProfileId String
  userProfile   UserProfile       @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  type          TherapyPlanType
  status        TherapyPlanStatus @default(DRAFT)

  title           String
  slogan          String?
  introduction    String
  startTime       DateTime
  endTime         DateTime?
  location        String
  maxParticipants Int?
  contactInfo     String
  price           Decimal?  @db.Decimal(10, 2) // per-seat price for Group/Art/Retreat

  // Type-specific fields
  artSalonSubType ArtSalonSubType? // only for ART_SALON
  sessionMedium   SessionMedium? // only for PERSONAL_CONSULT

  // Poster — one of these two is set, never both
  defaultPosterId Int? // 1–6 (static file /posters/default-N.jpg)
  posterUrl       String? // Cloudinary URL for custom upload
  videoUrl        String? // Cloudinary video URL for intro/promo video

  // Supplementary attachment
  attachmentUrl  String? // Cloudinary URL for PDF attachment
  attachmentName String? // Original filename shown to client

  // Review workflow
  rejectionReason String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  publishedAt     DateTime?

  messages     Message[]
  participants TherapyPlanParticipant[] @relation("PlanParticipants")
  events       TherapyPlanEvent[]       @relation("PlanEvents")
  images       TherapyPlanImage[]       @relation("PlanImages")
  pdfs         TherapyPlanPdf[]         @relation("PlanPdfs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([userProfileId])
}

model TherapyPlanEvent {
  id          String      @id @default(cuid())
  planId      String
  plan        TherapyPlan @relation("PlanEvents", fields: [planId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime?
  title       String?
  isAvailable Boolean     @default(true)
  order       Int         @default(0)

  @@index([planId])
}

model TherapyPlanImage {
  id        String      @id @default(cuid())
  planId    String
  plan      TherapyPlan @relation("PlanImages", fields: [planId], references: [id], onDelete: Cascade)
  url       String
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([planId])
}

model TherapyPlanPdf {
  id        String      @id @default(cuid())
  planId    String
  plan      TherapyPlan @relation("PlanPdfs", fields: [planId], references: [id], onDelete: Cascade)
  url       String
  name      String
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([planId])
}

model TherapyPlanTemplate {
  id          String          @id @default(cuid())
  createdById String
  createdBy   User            @relation("UserTemplates", fields: [createdById], references: [id], onDelete: Cascade)
  type        TherapyPlanType
  name        String          @db.VarChar(100)
  isPublic    Boolean         @default(false)
  data        Json
  createdAt   DateTime        @default(now())

  @@index([createdById])
  @@index([type, isPublic])
}

model TherapyPlanParticipant {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation("UserParticipations", fields: [userId], references: [id], onDelete: Cascade)
  planId     String
  plan       TherapyPlan       @relation("PlanParticipants", fields: [planId], references: [id], onDelete: Cascade)
  status     ParticipantStatus @default(SIGNED_UP)
  enrolledAt DateTime          @default(now())
  payment    PlanPayment?

  @@unique([userId, planId])
  @@index([planId])
}

model PlanPayment {
  id            String                 @id @default(cuid())
  participantId String                 @unique
  participant   TherapyPlanParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  provider              PaymentProvider @default(ALIPAY)
  externalOrderId       String?
  externalTradeNo       String?
  stripePaymentIntentId String?

  amount                Int
  currency              String @default("cny")
  platformFeeAmount     Int
  therapistPayoutAmount Int

  status       PaymentStatus @default(PENDING)
  refundedAt   DateTime?
  refundAmount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id          String  @id @default(cuid())
  senderId    String? // null = system-generated
  sender      User?   @relation("MessageSender", fields: [senderId], references: [id])
  recipientId String
  recipient   User    @relation("MessageRecipient", fields: [recipientId], references: [id])

  body    String // plain text + emoji, max 2000 chars
  trigger MessageTrigger
  isRead  Boolean        @default(false)
  readAt  DateTime?

  planId String?
  plan   TherapyPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([recipientId])
}

// ─── Artist & E-Commerce System ────────────────────────────────────────────────

model Product {
  id              String          @id @default(cuid())
  userProfileId   String
  userProfile     UserProfile     @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  title           String
  description     String
  price           Decimal         @db.Decimal(10, 2)
  stock           Int             @default(0)
  category        ProductCategory @default(OTHER)
  status          ProductStatus   @default(DRAFT)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  rejectionReason String?
  images          ProductImage[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userProfileId])
  @@index([category])
  @@index([status])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  totalAmount Int // Amount in cents (CNY/RMB)
  status      OrderStatus @default(PENDING)

  // Chinese Shipping Address
  province      String
  city          String
  district      String
  addressDetail String
  recipientName String
  phone         String

  // Logistics
  carrierName    String?
  trackingNumber String?

  items   OrderItem[]
  payment ProductPayment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Int // Snapshot of product price (in cents) at time of order

  @@index([orderId])
}

model ProductPayment {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider              PaymentProvider @default(ALIPAY)
  externalOrderId       String?
  externalTradeNo       String?
  stripePaymentIntentId String?

  amount   Int
  currency String @default("cny")

  status       PaymentStatus @default(PENDING)
  refundedAt   DateTime?
  refundAmount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Unified Profile System (New) ──────────────────────────────────────────────

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio             String?
  locationCity    String?
  socialMediaLink String?
  portfolioUrl    String?
  featuredImageUrl String?
  socialLinks     Json?    // {website, instagram, facebook}

  // Privacy & Visibility
  privateFields   Json?
  calendarVisible Boolean  @default(false)
  showcaseConfig  Json?
  showcaseOrder   Json?    // [{type: 'plan'|'product', id: string, visible: boolean, order: number}]
  profileViews    Int      @default(0)

  // Extended Metadata
  birthday        DateTime?
  telephone       String?
  region          String?
  religion        String?
  qrCodeUrl       String?

  // Profile Approval Workflow
  profileStatus   ProfileStatus @default(DRAFT)
  rejectionReason String?
  submittedAt     DateTime?
  reviewedAt      DateTime?

  // Certificates unlocked
  certificates    UserCertificate[]

  specialties     String[]
  sessionPrice    Decimal?  @db.Decimal(10, 2)
  sessionLength   Int?
  isAccepting     Boolean   @default(true)
  rating          Float?
  reviewCount     Int       @default(0)

  consultEnabled   Boolean  @default(false)
  hourlyConsultFee Decimal? @db.Decimal(10, 2)

  stripeAccountId     String?
  stripeAccountStatus StripeAccountStatus @default(NOT_CONNECTED)

  // Relations
  products         Product[]
  therapyPlans     TherapyPlan[]
  appointments     Appointment[]
  availability     Availability[]
  reviews          Review[]
  refundPolicy     RefundPolicy?
  galleryImages    GalleryImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCertificate {
  id              String            @id @default(cuid())
  profileId       String
  profile         UserProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type            CertificateType
  status          CertificateStatus @default(PENDING)
  certificateUrl  String?
  certificateUrls String[]
  tosAcceptedAt   DateTime?
  rejectionReason String?
  appliedAt       DateTime          @default(now())
  reviewedAt      DateTime?

  @@unique([profileId, type])
}
