# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/arttherapy"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Art Therapy App <noreply@arttherapy.com>"

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PLATFORM_FEE_PERCENT=15
STRIPE_CONNECT_RETURN_URL="http://localhost:3001/api/v1/payments/connect/return"
STRIPE_CONNECT_REFRESH_URL="http://localhost:3001/api/v1/payments/connect/refresh"

# App
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"
# Set to false to disable payment enforcement (skips Stripe account check, auto-confirms appointments)
PAYMENTS_ENABLED=true

# Chinese payment methods — Alipay (支付宝) and WeChat Pay (微信支付)
# Set to true once merchant accounts are configured. Default: false (disabled).
ALIPAY_ENABLED=false
WECHAT_ENABLED=false

# Exchange rate API (cn.apihz.cn) — used to show USD equivalent of CNY prices for English users.
# Register a free account at https://www.apihz.cn to get your own ID and KEY.
# The default public demo key (88888888) is shared and heavily rate-limited.
APIHZ_ID="88888888"
APIHZ_KEY="88888888"

# DeepL translation API (used by optional bilingual auto-fill in plan/product review steps)
DEEPL_API_KEY=""
DEEPL_API_BASE_URL="https://api-free.deepl.com"
TRANSLATE_TIMEOUT_MS=8000

# Alipay Open Platform credentials
# https://open.alipay.com — use sandbox gateway for testing: https://openapi.alipaydev.com/gateway.do
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""       # RSA2 private key (PEM, no line breaks in env file)
ALIPAY_PUBLIC_KEY=""        # Alipay public key from Open Platform console
ALIPAY_NOTIFY_URL="http://localhost:3001/webhooks/alipay"
ALIPAY_RETURN_URL="http://localhost:5173/booking/confirmation"

# WeChat Pay v3 credentials
# https://pay.weixin.qq.com — API v3 requires certificate-based auth
WECHAT_APP_ID=""            # WeChat Official Account / Mini Program App ID
WECHAT_MCH_ID=""            # Merchant ID (商户号)
WECHAT_PRIVATE_KEY=""       # API private key (PEM, from merchant platform)
WECHAT_CERT_SERIAL=""       # Merchant API certificate serial number
WECHAT_PLATFORM_SERIAL=""   # WeChat Pay platform certificate serial number
WECHAT_PLATFORM_CERT=""     # WeChat Pay platform certificate (PEM)
WECHAT_API_V3_KEY=""        # API v3 key (32 chars, set in merchant dashboard)
WECHAT_NOTIFY_URL="http://localhost:3001/webhooks/wechat"
